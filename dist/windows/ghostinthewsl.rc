// LANG_NEUTRAL(0), SUBLANG_NEUTRAL(0)
LANGUAGE 0, 0

#define RT_MANIFEST 1
RT_MANIFEST 24 "ghostty.manifest"

#define ID_ICON_GHOSTWSL 1
ID_ICON_GHOSTWSL ICON "ghostty.ico"

VS_VERSION_INFO VERSIONINFO
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
        VALUE "OriginalFilename", "ghostinthewsl.exe"
        VALUE "ProductName", "GhostInTheWSL"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
